# 服务端持久化目录（Docker 镜像默认 /data；Vercel 不要设）
# DATA_DIR=/data

# 可选：服务端内置 GitHub PAT
# 仅服务端进程可读，不会下发到浏览器 / 不会进入 localStorage
# 用户在设置页填了自己的 token 会优先覆盖此项
# 申请方式：https://github.com/settings/personal-access-tokens/new
#   Repository access 选 Public Repositories (read-only) 即可
# GITHUB_TOKEN=github_pat_xxx

# 可选：服务端内置 Gitee 私人令牌
# GITEE_TOKEN=
